# Descomplicita Frontend — Environment Variables
# Copy to .env.local and fill in values

# Backend API URL
BACKEND_URL=http://localhost:8000

# API key for backend authentication (server-side only, NOT public)
BACKEND_API_KEY=your-secret-api-key-here

# Supabase (v3-story-2.0 — public keys, safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Analytics (optional)
NEXT_PUBLIC_MIXPANEL_TOKEN=

# Sentry error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Download TTL in milliseconds (default: 1 hour)
DOWNLOAD_TTL_MS=3600000
