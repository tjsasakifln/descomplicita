# Descomplicita Backend — Environment Variables
# Copy to .env and fill in values

# Server
PORT=8000
LOG_LEVEL=INFO

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://descomplicita.vercel.app,http://localhost:3000

# Authentication — API key for all non-public endpoints
API_KEY=your-secret-api-key-here

# Debug endpoints — set to "true" to enable /cache/stats, /cache/clear, /debug/pncp-test
ENABLE_DEBUG_ENDPOINTS=false

# External APIs
TRANSPARENCIA_API_KEY=
OPENAI_API_KEY=

# Supabase (v3-story-2.0)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
